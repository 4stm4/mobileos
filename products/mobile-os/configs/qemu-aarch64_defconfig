# Target: QEMU aarch64 virt (Cortex-A53, for development/testing)
BR2_aarch64=y
BR2_cortex_a53=y

# Toolchain
BR2_TOOLCHAIN_EXTERNAL=y
BR2_TOOLCHAIN_EXTERNAL_BOOTLIN=y
BR2_TOOLCHAIN_EXTERNAL_BOOTLIN_AARCH64_MUSL=y

# Linux kernel — upstream virt
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_LATEST_VERSION=y
BR2_LINUX_KERNEL_DEFCONFIG="defconfig"
BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_MOBILEOS_PATH)/board/qemu-aarch64/linux.config"
BR2_LINUX_KERNEL_IMAGE_TARGET_NAME="Image"
BR2_LINUX_KERNEL_NEEDS_HOST_OPENSSL=y

# System
BR2_TARGET_GENERIC_HOSTNAME="mobileos-qemu"
BR2_TARGET_GENERIC_ISSUE="4STM4 Mobile OS (QEMU)"
BR2_TARGET_GENERIC_ROOT_PASSWD=""

# Init system
BR2_INIT_SYSV=y

# Filesystem — raw ext4, no genimage needed for QEMU
BR2_TARGET_ROOTFS_EXT2=y
BR2_TARGET_ROOTFS_EXT2_4=y
BR2_TARGET_ROOTFS_EXT2_SIZE="512M"

# Host Rust toolchain (for Rust packages)
BR2_PACKAGE_HOST_RUSTC=y

# Base packages
BR2_PACKAGE_BUSYBOX=y
BR2_PACKAGE_LOGROTATE=y
BR2_PACKAGE_DROPBEAR=y
BR2_PACKAGE_SQLITE=y
BR2_PACKAGE_SQLITE_ENABLE_JSON=y

# Mobile OS packages (QEMU subset — no display/telephony/TDLib)
BR2_PACKAGE_COMMD=y
BR2_PACKAGE_NETD=y
BR2_PACKAGE_POWERD=y
BR2_PACKAGE_LOCALBE=y
BR2_PACKAGE_HARDWARED=y

# Disabled for QEMU (no hardware, no display)
# BR2_PACKAGE_MOBILE_SHELL is not set
# BR2_PACKAGE_SIMD is not set
# BR2_PACKAGE_TELEGRAMD is not set
# BR2_PACKAGE_TDJSON is not set
# BR2_PACKAGE_LIBDRM is not set
# BR2_PACKAGE_LVGL is not set
# BR2_PACKAGE_LIBINPUT is not set
# BR2_PACKAGE_RPI_FIRMWARE is not set

# Filesystem scripts
BR2_ROOTFS_OVERLAY="$(BR2_EXTERNAL_MOBILEOS_PATH)/board/qemu-aarch64/rootfs_overlay"
BR2_ROOTFS_POST_BUILD_SCRIPT="$(BR2_EXTERNAL_MOBILEOS_PATH)/board/qemu-aarch64/post-build.sh"
