# Target: Raspberry Pi Zero 2 W (BCM2710, ARM Cortex-A53 @ 1GHz)
BR2_aarch64=y
BR2_cortex_a53=y
BR2_ARM_FPU_NEON_FP_ARMV8=y

# Toolchain
BR2_TOOLCHAIN_EXTERNAL=y
BR2_TOOLCHAIN_EXTERNAL_BOOTLIN=y
BR2_TOOLCHAIN_EXTERNAL_BOOTLIN_AARCH64_MUSL=y

# Linux kernel
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_CUSTOM_GIT=y
BR2_LINUX_KERNEL_CUSTOM_REPO_URL="https://github.com/raspberrypi/linux.git"
BR2_LINUX_KERNEL_CUSTOM_REPO_VERSION="rpi-6.6.y"
BR2_LINUX_KERNEL_DEFCONFIG="bcm2711"
BR2_LINUX_KERNEL_IMAGE_TARGET_NAME="Image.gz"
BR2_LINUX_KERNEL_NEEDS_HOST_OPENSSL=y

# Boot
BR2_TARGET_ROOTFS_EXT2=y
BR2_TARGET_ROOTFS_EXT2_4=y
BR2_TARGET_ROOTFS_EXT2_SIZE="512M"
BR2_TARGET_UBOOT=n

# Raspberry Pi firmware
BR2_PACKAGE_RPI_FIRMWARE=y
BR2_PACKAGE_RPI_FIRMWARE_VARIANT_PI0_2=y
BR2_PACKAGE_RPI_FIRMWARE_CONFIG_FILE="$(BR2_EXTERNAL_MOBILEOS_PATH)/board/zero2w-phone/config.txt"

# System
BR2_TARGET_GENERIC_HOSTNAME="mobileos"
BR2_TARGET_GENERIC_ISSUE="4STM4 Mobile OS"
BR2_SYSTEM_DHCP="eth0"
BR2_TARGET_GENERIC_ROOT_PASSWD=""

# Init system
BR2_INIT_SYSV=y

# Base packages
BR2_PACKAGE_BUSYBOX=y
BR2_PACKAGE_BUSYBOX_CONFIG="$(BR2_EXTERNAL_MOBILEOS_PATH)/board/zero2w-phone/busybox.config"
BR2_PACKAGE_DROPBEAR=y
BR2_PACKAGE_SQLITE=y
BR2_PACKAGE_SQLITE_ENABLE_JSON=y

# Mobile OS packages
BR2_PACKAGE_MOBILE_SHELL=y
BR2_PACKAGE_COMMD=y
BR2_PACKAGE_SIMD=y
BR2_PACKAGE_NETD=y
BR2_PACKAGE_TELEGRAMD=y
BR2_PACKAGE_LOCALBE=y
BR2_PACKAGE_HARDWARED=y
BR2_PACKAGE_POWERD=y

# Filesystem overlay
BR2_ROOTFS_OVERLAY="$(BR2_EXTERNAL_MOBILEOS_PATH)/board/zero2w-phone/rootfs_overlay"
BR2_ROOTFS_POST_BUILD_SCRIPT="$(BR2_EXTERNAL_MOBILEOS_PATH)/board/zero2w-phone/post-build.sh"
BR2_ROOTFS_POST_IMAGE_SCRIPT="$(BR2_EXTERNAL_MOBILEOS_PATH)/board/zero2w-phone/post-image.sh"
