# Minimal BusyBox config for mobile-os
# Generated for 4STM4 Mobile OS — adjust as needed

CONFIG_FEATURE_INSTALLER=n
CONFIG_INSTALL_APPLET_DONT=y

# Core utils
CONFIG_ASH=y
CONFIG_ASH_BASH_COMPAT=y
CONFIG_MOUNT=y
CONFIG_UMOUNT=y
CONFIG_CHMOD=y
CONFIG_CHOWN=y
CONFIG_CHGRP=y
CONFIG_CP=y
CONFIG_MV=y
CONFIG_RM=y
CONFIG_MKDIR=y
CONFIG_RMDIR=y
CONFIG_LN=y
CONFIG_LS=y
CONFIG_CAT=y
CONFIG_ECHO=y
CONFIG_GREP=y
CONFIG_SED=y
CONFIG_AWK=y
CONFIG_SORT=y
CONFIG_UNIQ=y
CONFIG_CUT=y
CONFIG_WC=y
CONFIG_HEAD=y
CONFIG_TAIL=y
CONFIG_FIND=y
CONFIG_XARGS=y
CONFIG_DATE=y
CONFIG_SLEEP=y
CONFIG_KILL=y
CONFIG_PS=y
CONFIG_TOP=y
CONFIG_FREE=y
CONFIG_DF=y
CONFIG_DU=y
CONFIG_SYNC=y
CONFIG_UNAME=y
CONFIG_HOSTNAME=y
CONFIG_WHOAMI=y
CONFIG_ID=y
CONFIG_STAT=y
CONFIG_TOUCH=y
CONFIG_PRINTF=y
CONFIG_TEST=y
CONFIG_EXPR=y

# Init / sysvinit helpers
CONFIG_INIT=y
CONFIG_SYSLOG=y
CONFIG_KLOGD=y
CONFIG_SYSLOGD=y
CONFIG_HALT=y
CONFIG_POWEROFF=y
CONFIG_REBOOT=y

# Networking
CONFIG_IFCONFIG=y
CONFIG_ROUTE=y
CONFIG_PING=y
CONFIG_UDHCPC=y
CONFIG_UDHCPD=y
CONFIG_WGET=y
CONFIG_NTPD=n

# Misc
CONFIG_LESS=y
CONFIG_VI=y
CONFIG_DMESG=y
CONFIG_MDEV=y
CONFIG_FEATURE_MDEV_DAEMON=y
