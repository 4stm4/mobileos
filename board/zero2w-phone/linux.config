# Linux kernel config fragment for Raspberry Pi Zero 2 W (BCM2710)
# Applied on top of bcm2711_defconfig via BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES

# --- ARM64 / SMP ---
CONFIG_SMP=y
CONFIG_NR_CPUS=4
CONFIG_HAVE_ARM_ARCH_TIMER=y

# --- MMC / SD ---
CONFIG_MMC=y
CONFIG_MMC_BCM2835=y
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_PLTFM=y
CONFIG_MMC_SDHCI_IPROC=y

# --- USB (OTG dwc2 peripheral) ---
CONFIG_USB=y
CONFIG_USB_GADGET=y
CONFIG_USB_DWC2=y
CONFIG_USB_DWC2_PERIPHERAL=y
CONFIG_USB_G_SERIAL=y

# --- UART (PL011 for console + SIM800L) ---
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y

# --- I2C (HAT EEPROM, AXP power IC) ---
CONFIG_I2C=y
CONFIG_I2C_BCM2835=y

# --- SPI ---
CONFIG_SPI=y
CONFIG_SPI_BCM2835=y
CONFIG_SPI_BCM2835AUX=y

# --- GPIO ---
CONFIG_GPIOLIB=y
CONFIG_GPIO_SYSFS=y
CONFIG_GPIO_BCM_VIRT=y

# --- DRM / display ---
CONFIG_DRM=y
CONFIG_DRM_VC4=y
CONFIG_DRM_PANEL=y
CONFIG_DRM_MIPI_DSI=y

# --- Input ---
CONFIG_INPUT=y
CONFIG_INPUT_EVDEV=y
CONFIG_INPUT_TOUCHSCREEN=y
CONFIG_TOUCHSCREEN_EDT_FT5X06=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_KEYBOARD_GPIO=y

# --- Power supply / battery ---
CONFIG_POWER_SUPPLY=y
CONFIG_BATTERY_AXP20X=y
CONFIG_CHARGER_AXP20X=y
CONFIG_MFD_AXP20X=y
CONFIG_MFD_AXP20X_I2C=y

# --- Backlight ---
CONFIG_BACKLIGHT_CLASS_DEVICE=y
CONFIG_BACKLIGHT_GPIO=y
CONFIG_BACKLIGHT_PWM=y

# --- Networking ---
CONFIG_NET=y
CONFIG_INET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_IPV6=y

# --- WireGuard ---
CONFIG_WIREGUARD=y
CONFIG_CRYPTO_CHACHA20POLY1305=y
CONFIG_CRYPTO_BLAKE2S=y
CONFIG_CRYPTO_CURVE25519=y

# --- Wi-Fi (onboard CYW43438) ---
CONFIG_BRCMFMAC=y
CONFIG_BRCMUTIL=y
CONFIG_CFG80211=y
CONFIG_MAC80211=y
CONFIG_RFKILL=y

# --- Filesystem ---
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_VFAT_FS=y
CONFIG_FAT_DEFAULT_CODEPAGE=437
CONFIG_FAT_DEFAULT_IOCHARSET="ascii"
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_SQUASHFS=n

# --- RTC ---
CONFIG_RTC_CLASS=y
CONFIG_RTC_HCTOSYS=y
CONFIG_RTC_DRV_PCF8523=y
CONFIG_RTC_DRV_DS3231=y

# --- Watchdog ---
CONFIG_WATCHDOG=y
CONFIG_BCM2835_WDT=y

# --- Security / disable debug bloat ---
CONFIG_SECURITY=y
CONFIG_SECCOMP=y
CONFIG_KALLSYMS=n
CONFIG_SYSFS_SYSCALL=y
CONFIG_PROC_SYSCTL=y
CONFIG_DEBUG_KERNEL=n
CONFIG_FTRACE=n
CONFIG_KPROBES=n
